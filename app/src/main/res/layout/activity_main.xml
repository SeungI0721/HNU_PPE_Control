<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Smart Shield 작업자 앱"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtBleState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="BLE 상태: 대기"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/txtReconnectState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="재연결 상태: 대기"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtConnectedDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="연결 장치: 없음"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BLE 스캔" />

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="연결 해제" />
    </LinearLayout>

    <Button
        android:id="@+id/btnFakeData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fake 데이터 테스트" />

    <ListView
        android:id="@+id/listBle"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/txtData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="센서 데이터 없음"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/txtRiskCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="ESP32 명령: 없음"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/txtFirebaseState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Firebase 상태: 대기"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtLastUpdate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="마지막 업데이트: 없음"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtRiskState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#777777"
        android:gravity="center"
        android:padding="16dp"
        android:text="상태: 대기"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

</LinearLayout>
